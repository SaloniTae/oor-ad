# ============================================================================
# Streaming Security layer (device-limit + signed URLs)
# Append these to server/.env.example
# ============================================================================

# Universal HMAC secret used to sign m3u8 segment URIs and MP4 refresh URLs.
# REQUIRED. 32+ random characters. Rotate periodically.
HMAC_SIGNING_SECRET=change-me-32-plus-chars-random-string-here

# ONLY needed when a channel's origin_type is set to "bunny" (Bunny.net Pull
# Zone with Token Authentication enabled). One key per Pull Zone.
BUNNY_SECURITY_KEY=

# ONLY needed when a channel's origin_type is set to "nginx" (self-hosted
# nginx with ngx_http_secure_link_module).
NGINX_SECURE_LINK_SECRET=

# Redis is REQUIRED for the session registry + cluster fan-out. Leave as
# the default to talk to a co-located Redis; point at a managed instance
# in production.
REDIS_URL=redis://127.0.0.1:6379

# Rate limit: how many /v1/stream/authorize calls per PIN per 5 minutes.
STREAM_AUTHORIZE_RPM=10

# Signed-URL TTLs (seconds).
STREAM_SEGMENT_TTL_SEC=60
STREAM_MP4_TTL_SEC=300
STREAM_REFRESH_WINDOW_SEC=30

# Optional: number of workers when running via `node src/cluster.js`.
# Defaults to the number of CPUs.
# CLUSTER_WORKERS=4
