# Public-facing hostname / IP (used in issued URLs)
PUBLIC_URL=http://localhost:7860

# Ports
PORT=7860              # single-port production server

# Persistence
DATA_DIR=./data        # sqlite file + uploaded ad files live here
DB_FILE=./data/app.db
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_MB=200

# Secrets (CHANGE THESE)
JWT_SECRET=change-me-to-a-long-random-string-32chars-min
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=changeme-please-set-in-env

# Rate limits (per API key, sliding window)
RATE_LIMIT_RPM=120

# CORS: comma-separated origins allowed by default for the admin UI itself
ADMIN_CORS=

# Optional Redis (enables horizontal scale; leave empty for single-node)
REDIS_URL=

# Logging
LOG_LEVEL=info
NODE_ENV=production

# Iframe embedding control for the /player page.
# - Empty or unset: ALLOW ALL origins (best for local testing – no X-Frame errors).
# - "*"            : allow all (explicit).
# - "self"         : same-origin only (production default when you don't embed anywhere).
# - "https://a.com,https://b.com" : only these origins may embed the player.
# Both X-Frame-Options and CSP frame-ancestors are handled – put your customer
# domains here to restrict who can embed your player.
IFRAME_ALLOW_ORIGINS=
