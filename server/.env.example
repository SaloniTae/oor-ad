# --- Public URLs (set to your domain or VPS IP) ---
PUBLIC_HOST=YOUR_VPS_IP

# --- Ports ---
WS_PORT=6778           # WebSocket viewer server
ADMIN_PORT=6779        # Admin REST API
STATIC_PORT=6780       # Static site (player + admin UI)

# --- Redis (for horizontal scaling / pub-sub fan-out) ---
REDIS_URL=redis://127.0.0.1:6379

# --- Auth ---
# Long random string. Only holders can trigger ads.
ADMIN_TOKEN=change-me-to-a-long-random-string

# --- Streams ---
LIVE_HLS_URL=https://test-streams.mux.dev/x36xhzz/x36xhzz.m3u8

# --- Ops ---
NODE_ENV=production
LOG_LEVEL=info
# Node cluster workers (0 = auto = CPU count)
CLUSTER_WORKERS=0
